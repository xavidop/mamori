# Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX).
# When set, the docs site loads gtag.js ONLY after a visitor accepts the cookie
# banner, and never if they decline. Leave empty to disable analytics entirely.
#
# Locally:   copy this file to .env and fill it in.
# In CI:     set a repository variable named GA_ID (the Pages workflow maps it
#            to PUBLIC_GA_ID at build time).
PUBLIC_GA_ID=
