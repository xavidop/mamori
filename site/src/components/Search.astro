---
// Command-palette docs search. At build time we index every docs Markdown page
// (title + headings + plain-text body) and embed it as JSON; a client script
// filters it live in a modal. Dependency-free, works on static hosting.
const base = import.meta.env.BASE_URL;

const pages = import.meta.glob("/src/pages/docs/**/*.md", { eager: true });

const hrefFor = (slug: string) => {
  const p = (base + "docs/" + slug).replace(/\/+$/, "");
  return p === "" ? "/" : p;
};

const stripMd = (md: string) =>
  md
    .replace(/^---[\s\S]*?---/, "")
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/[#>*_|~-]/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 1600);

const index = Object.entries(pages)
  .map(([key, mod]: [string, any]) => {
    const slug = key
      .replace("/src/pages/docs/", "")
      .replace(/\.md$/, "")
      .replace(/\/?index$/, "");
    const headings = (typeof mod.getHeadings === "function" ? mod.getHeadings() : [])
      .filter((h: any) => h.depth >= 2 && h.depth <= 3)
      .map((h: any) => ({ text: h.text, slug: h.slug }));
    const raw = typeof mod.rawContent === "function" ? mod.rawContent() : "";
    return {
      title: mod.frontmatter?.title ?? (slug || "Introduction"),
      href: hrefFor(slug),
      section: slug.startsWith("providers/") ? "Providers" : "Docs",
      headings,
      text: stripMd(raw).toLowerCase(),
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));
---

<button class="dsearch-trigger" data-search-open type="button">
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
    <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
  </svg>
  <span>Search docs</span>
  <kbd>/</kbd>
</button>

<div class="dsearch" data-search-modal hidden>
  <div class="dsearch__backdrop" data-search-close></div>
  <div class="dsearch__panel" role="dialog" aria-modal="true" aria-label="Search documentation">
    <div class="dsearch__head">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
        <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
      <input
        type="search"
        class="dsearch__input"
        placeholder="Search the docs..."
        aria-label="Search documentation"
        autocomplete="off"
        spellcheck="false"
        data-search-input
      />
      <kbd class="dsearch__esc">Esc</kbd>
    </div>
    <div class="dsearch__results" data-search-results role="listbox" aria-label="Search results"></div>
    <div class="dsearch__foot">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script type="application/json" data-search-index set:html={JSON.stringify(index)}></script>

<script>
  type Heading = { text: string; slug: string };
  type Page = { title: string; href: string; section: string; headings: Heading[]; text: string };

  const modal = document.querySelector<HTMLElement>("[data-search-modal]");
  const trigger = document.querySelector<HTMLButtonElement>("[data-search-open]");
  const input = document.querySelector<HTMLInputElement>("[data-search-input]");
  const results = document.querySelector<HTMLElement>("[data-search-results]");
  const raw = document.querySelector("[data-search-index]")?.textContent ?? "[]";
  const index: Page[] = JSON.parse(raw);

  if (modal && trigger && input && results) {
    let items: HTMLAnchorElement[] = [];
    let active = -1;

    const open = () => {
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      input.value = "";
      render("");
      requestAnimationFrame(() => input.focus());
    };
    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = "";
    };

    const score = (p: Page, terms: string[]) => {
      const title = p.title.toLowerCase();
      let s = 0;
      let heading: Heading | null = null;
      for (const t of terms) {
        if (title.includes(t)) s += 10;
        const h = p.headings.find((h) => h.text.toLowerCase().includes(t));
        if (h) {
          s += 5;
          if (!heading) heading = h;
        }
        if (p.text.includes(t)) s += 1;
      }
      const all = terms.every(
        (t) => title.includes(t) || p.text.includes(t) || p.headings.some((h) => h.text.toLowerCase().includes(t)),
      );
      return { s: all ? s : 0, heading };
    };

    const render = (q: string) => {
      const terms = q.toLowerCase().split(/\s+/).filter(Boolean);
      if (terms.length === 0) {
        results.innerHTML = `<p class="dsearch__hint">Start typing to search ${index.length} pages.</p>`;
        items = [];
        active = -1;
        return;
      }
      const ranked = index
        .map((p) => ({ p, ...score(p, terms) }))
        .filter((r) => r.s > 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 10);

      if (ranked.length === 0) {
        results.innerHTML = `<p class="dsearch__hint">No results for "${q.replace(/</g, "&lt;")}".</p>`;
        items = [];
        active = -1;
        return;
      }

      results.innerHTML = ranked
        .map(({ p, heading }) => {
          const href = heading ? `${p.href}#${heading.slug}` : p.href;
          const crumb = heading ? `${p.section} › ${p.title}` : p.section;
          const line2 = heading ? heading.text : p.title;
          return `<a class="dsearch__hit" role="option" href="${href}">
            <span class="dsearch__crumb">${crumb}</span>
            <span class="dsearch__label">${line2}</span>
          </a>`;
        })
        .join("");
      items = Array.from(results.querySelectorAll<HTMLAnchorElement>(".dsearch__hit"));
      setActive(0);
    };

    const setActive = (i: number) => {
      items.forEach((el) => el.classList.remove("is-active"));
      if (i >= 0 && i < items.length) {
        active = i;
        items[i].classList.add("is-active");
        items[i].scrollIntoView({ block: "nearest" });
      } else {
        active = -1;
      }
    };

    trigger.addEventListener("click", open);
    modal.querySelector("[data-search-close]")?.addEventListener("click", close);
    input.addEventListener("input", () => render(input.value));

    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(Math.min(active + 1, items.length - 1));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(Math.max(active - 1, 0));
      } else if (e.key === "Enter") {
        e.preventDefault();
        const el = items[active] ?? items[0];
        if (el) window.location.href = el.href;
      } else if (e.key === "Escape") {
        close();
      }
    });

    document.addEventListener("keydown", (e) => {
      const el = document.activeElement;
      const typing = el && (el.tagName === "INPUT" || el.tagName === "TEXTAREA");
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        modal.hidden ? open() : close();
      } else if (e.key === "/" && !typing && modal.hidden) {
        e.preventDefault();
        open();
      } else if (e.key === "Escape" && !modal.hidden) {
        close();
      }
    });
  }
</script>

<style is:global>
  .dsearch-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    margin-bottom: 1.5rem;
    padding: 0.55rem 0.7rem;
    background: var(--bg-2);
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 0.9rem;
    cursor: pointer;
    transition:
      border-color 0.2s var(--ease),
      box-shadow 0.2s var(--ease);
  }
  .dsearch-trigger:hover {
    border-color: var(--green);
    box-shadow: 0 0 0 3px var(--green-soft);
  }
  .dsearch-trigger svg {
    color: var(--muted-2);
    flex: none;
  }
  .dsearch-trigger span {
    flex: 1;
    text-align: left;
  }
  .dsearch-trigger kbd,
  .dsearch__esc,
  .dsearch__foot kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted-2);
    border: 1px solid var(--line-strong);
    border-radius: 5px;
    padding: 0 0.35rem;
    background: var(--bg);
    line-height: 1.5;
  }

  /* Modal */
  .dsearch {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 12vh 1rem 1rem;
  }
  .dsearch[hidden] {
    display: none;
  }
  .dsearch__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(27, 32, 25, 0.32);
    backdrop-filter: blur(3px);
    animation: fade 0.15s var(--ease);
  }
  .dsearch__panel {
    position: relative;
    width: min(600px, 100%);
    background: var(--bg-2);
    border: 1px solid var(--line-strong);
    border-radius: 16px;
    box-shadow: 0 30px 70px -24px rgba(27, 32, 25, 0.45);
    overflow: hidden;
    animation: pop 0.16s var(--ease);
  }
  @keyframes fade {
    from {
      opacity: 0;
    }
  }
  @keyframes pop {
    from {
      opacity: 0;
      transform: translateY(-8px) scale(0.98);
    }
  }
  .dsearch__head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .dsearch__head svg {
    color: var(--green);
    flex: none;
  }
  .dsearch__input {
    flex: 1;
    border: 0;
    background: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--ink);
    min-width: 0;
  }
  .dsearch__input::placeholder {
    color: var(--muted-2);
  }
  .dsearch__results {
    max-height: 52vh;
    overflow-y: auto;
    padding: 0.5rem;
  }
  .dsearch__hit {
    display: block;
    padding: 0.6rem 0.8rem;
    border-radius: 10px;
    text-decoration: none;
  }
  .dsearch__hit:hover,
  .dsearch__hit.is-active {
    background: var(--green-soft);
  }
  .dsearch__crumb {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted-2);
    margin-bottom: 0.1rem;
  }
  .dsearch__label {
    display: block;
    font-size: 0.98rem;
    color: var(--ink);
    font-weight: 500;
  }
  .dsearch__hit.is-active .dsearch__label {
    color: var(--green-deep);
  }
  .dsearch__hint {
    margin: 0;
    padding: 1.2rem 0.9rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .dsearch__foot {
    display: flex;
    gap: 1.1rem;
    padding: 0.6rem 1.1rem;
    border-top: 1px solid var(--line);
    font-size: 0.75rem;
    color: var(--muted-2);
  }
  .dsearch__foot span {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  @media (max-width: 900px) {
    .dsearch__foot {
      display: none;
    }
  }
</style>
