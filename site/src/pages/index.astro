---
import Layout from "../layouts/Layout.astro";
import ReconcileDemo from "../components/ReconcileDemo.astro";
import Seigaiha from "../components/Seigaiha.astro";
import Omamori from "../components/Omamori.astro";

const repo = "https://github.com/xavidop/mamori";
const base = import.meta.env.BASE_URL;
const docs = `${base}docs`;

const features = [
  {
    k: "01",
    t: "Typed loading",
    d: "One struct, tag-driven, many sources. A generics API - Load[T] and Watch[T] - decodes and validates into your own types. No stringly-typed lookups.",
  },
  {
    k: "02",
    t: "Runtime reconciliation",
    d: "Native watch where the backend supports it - Kubernetes informers, Consul blocking queries, fsnotify - polling with jitter everywhere else, and lease-aware refresh for Vault.",
  },
  {
    k: "03",
    t: "Atomic & validated",
    d: "An update that fails validation is rejected. Get() keeps returning the last good config. Your process never observes a half-applied or invalid state.",
  },
  {
    k: "04",
    t: "Secret hygiene",
    d: "secret.String redacts itself in logs, fmt, and JSON. Only Reveal() exposes the value - and a shipped go vet analyzer flags sensitive refs stored in plain strings.",
  },
];

// Providers are summarized on the landing by category; the full gallery lives in
// the docs. Each card links to a representative provider page.
const categories = [
  {
    name: "Built-in",
    count: 4,
    items: "env · dotenv · file · exec",
    href: `${base}docs/providers/env`,
  },
  {
    name: "Secret managers",
    count: 8,
    items: "AWS · Vault · GCP · Azure · Doppler · 1Password · SOPS",
    href: `${base}docs/providers/aws`,
  },
  {
    name: "Feature flags",
    count: 8,
    items: "LaunchDarkly · Unleash · Flagsmith · ConfigCat · Split · GrowthBook · Flipt · GO Feature Flag",
    href: `${base}docs/providers/launchdarkly`,
  },
  {
    name: "Databases",
    count: 7,
    items: "Postgres · MySQL · SQLite · MongoDB · Redis · DynamoDB · Cosmos",
    href: `${base}docs/providers/postgres`,
  },
  {
    name: "KV & Kubernetes",
    count: 4,
    items: "Consul · etcd · Kubernetes Secret · ConfigMap",
    href: `${base}docs/providers/kubernetes`,
  },
  {
    name: "Object storage & Firebase",
    count: 6,
    items: "S3 · GCS · Azure Blob · Firestore · Firebase RTDB · Remote Config",
    href: `${base}docs/providers/s3`,
  },
];
const totalProviders = categories.reduce((n, c) => n + c.count, 0);
---

<Layout>
  <!-- ░░ HERO ░░ -->
  <section class="hero">
    <Seigaiha />
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <span class="eyebrow">守り · config &amp; secrets for go</span>
        <h1 class="hero__title">Secrets that<br /><em>reconcile</em> themselves.</h1>
        <p class="hero__lede">
          <strong>mamori</strong> loads configuration and secrets from anywhere into typed,
          validated Go structs - then watches every source and reconciles changes at runtime.
          Rotate a database password upstream; your pool rotates too. <em>No restart.</em>
        </p>
        <div class="hero__cta">
          <a class="btn btn--primary" href={docs}>Read the docs →</a>
          <a class="btn btn--ghost" href={repo} target="_blank" rel="noopener">GitHub ↗</a>
        </div>
        <div class="hero__install">
          <code>go get github.com/xavidop/mamori</code>
        </div>
      </div>
      <div class="hero__demo">
        <ReconcileDemo />
      </div>
    </div>
  </section>

  <!-- ░░ CONCEPTS ░░ -->
  <section class="section" id="concepts">
    <div class="wrap">
      <div class="section__head">
        <span class="eyebrow">principles</span>
        <h2>Four ideas, composed.</h2>
        <p>Each does one thing, through a well-defined interface, testable on its own.</p>
      </div>
      <div class="features">
        {
          features.map((f) => (
            <article class="card feature">
              <span class="feature__k">{f.k}</span>
              <h3>{f.t}</h3>
              <p>{f.d}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ░░ QUICKSTART ░░ -->
  <section class="section" id="quickstart">
    <div class="wrap qs">
      <div class="section__head">
        <span class="eyebrow">quickstart</span>
        <h2>Declare it. Watch it.</h2>
        <p>
          Tag a struct with where each value lives. mamori resolves, validates, and - with
          <code>Watch</code> - keeps it reconciled, handing you a diff-aware callback.
        </p>
      </div>
      <div class="qs__grid">
        <pre class="code"><code><span class="c">// One struct, many sources.</span>
<span class="k">type</span> <span class="t">Config</span> <span class="k">struct</span> {'{'}
  DBPassword <span class="t">secret.String</span> <span class="s">`source:"aws-sm://prod/db#password"`</span>
  LogLevel   <span class="t">string</span>        <span class="s">`source:"env:LOG_LEVEL" default:"info"`</span>
  Workers    <span class="t">int</span>           <span class="s">`source:"env:WORKERS" validate:"gte=1,lte=256"`</span>
  TLSCert    []<span class="t">byte</span>        <span class="s">`source:"file:///etc/tls/tls.crt"`</span>
{'}'}</code></pre>
        <pre class="code"><code><span class="c">// Watch: reconcile at runtime, react without restarting.</span>
w, _ := <span class="f">mamori.Watch</span>[<span class="t">Config</span>](ctx,
  <span class="f">mamori.OnChange</span>(<span class="k">func</span>(ev <span class="t">mamori.Change</span>[<span class="t">Config</span>]) {'{'}
    <span class="k">if</span> ev.<span class="f">Changed</span>(<span class="s">"DBPassword"</span>) {'{'}
      pool.<span class="f">Rotate</span>(ev.New.DBPassword.<span class="f">Reveal</span>())
    {'}'}
  {'}'}),
)
<span class="k">defer</span> w.<span class="f">Close</span>()

cfg := w.<span class="f">Get</span>() <span class="c">// lock-free; always the last valid config</span></code></pre>
      </div>
    </div>
  </section>

  <!-- ░░ PROVIDERS ░░ -->
  <section class="section" id="providers">
    <div class="wrap">
      <div class="section__head">
        <span class="eyebrow">provider ecosystem</span>
        <h2>Read from where your secrets already live.</h2>
        <p>
          {totalProviders} sources across {categories.length} categories, all behind one
          interface. Providers register with the <code>database/sql</code> pattern, the core has
          zero cloud-SDK dependencies, and every provider passes the{" "}
          <code>providertest</code> conformance kit.
        </p>
      </div>
      <div class="cats">
        {
          categories.map((c) => (
            <a class="card cat" href={c.href}>
              <div class="cat__top">
                <h3 class="cat__name">{c.name}</h3>
                <span class="cat__count">{c.count}</span>
              </div>
              <p class="cat__items">{c.items}</p>
            </a>
          ))
        }
      </div>
      <div class="providers__cta">
        <a class="btn btn--primary" href={`${base}docs/providers`}>Browse all providers →</a>
        <a class="btn btn--ghost" href={`${base}docs/writing-a-provider`}>Write your own</a>
      </div>
    </div>
  </section>

  <!-- ░░ MIDDLEWARE ░░ -->
  <section class="section" id="middleware">
    <div class="wrap mw">
      <div class="mw__copy">
        <span class="eyebrow">middleware</span>
        <h2>One interface, so it all composes.</h2>
        <p>
          Because every provider is a <code>Provider</code>, decorators nest freely. Cache to
          cut API cost, fail over to a replica, rate-limit a twitchy backend, audit every
          resolve, or rewrite refs per tenant.
        </p>
        <ul class="mw__list">
          <li><b>Cache</b> - memoize resolves for a TTL</li>
          <li><b>Failover</b> - primary, then replicas</li>
          <li><b>RateLimit</b> - protect rate-limited backends</li>
          <li><b>Audit</b> - log every access, never the payload</li>
          <li><b>Prefix</b> - multi-tenant namespace rewriting</li>
        </ul>
      </div>
      <pre class="code mw__code"><code><span class="f">mamori.WithProvider</span>(
  <span class="f">middleware.Cache</span>(5*time.Minute,
    <span class="f">middleware.Audit</span>(logger,
      <span class="f">middleware.Failover</span>(
        primarySM,
        replicaSM,
      ),
    ),
  ),
)</code></pre>
    </div>
  </section>

  <!-- ░░ SECURITY ░░ -->
  <section class="section" id="security">
    <div class="wrap">
      <div class="section__head">
        <span class="eyebrow">security</span>
        <h2>Secret-safe by construction.</h2>
      </div>
      <div class="sec">
        <article class="card"><h3>Redacted everywhere</h3><p><code>secret.String</code> and <code>secret.Bytes</code> render as <code>[REDACTED]</code> in <code>String()</code>, <code>fmt</code>, JSON, and <code>slog</code>. Only <code>Reveal()</code> exposes the value - and it's greppable in review.</p></article>
        <article class="card"><h3>A vet analyzer</h3><p><code>reconcilevet</code> flags any secret-bearing ref assigned to a plain <code>string</code> or <code>[]byte</code>, so a leak can't slip past code review.</p></article>
        <article class="card"><h3>No injection chains</h3><p>The <code>exec:</code> provider is off by default. Refs are never interpolated from other resolved values - one secret can't build another's command.</p></article>
        <article class="card"><h3>Honest about limits</h3><p><code>Zero()</code> is best-effort and documented as such - no false promises about Go's GC. No payloads are ever logged; the conformance kit asserts it.</p></article>
      </div>
    </div>
  </section>

  <!-- ░░ CLOSING ░░ -->
  <section class="section closing">
    <div class="wrap closing__inner">
      <Omamori size={64} glow={true} />
      <h2>Give your config a guardian.</h2>
      <p>Typed. Watched. Reconciled. Runs in a Lambda, a systemd unit, or a Pod.</p>
      <div class="hero__cta">
        <a class="btn btn--primary" href={docs}>Read the docs →</a>
        <a class="btn btn--ghost" href={repo} target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    padding-block: clamp(3rem, 2rem + 6vw, 7rem) clamp(4rem, 3rem + 6vw, 8rem);
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 3rem;
    align-items: center;
  }
  .hero__title {
    font-size: var(--step-5);
    margin: 1.1rem 0 0;
  }
  .hero__title em {
    font-style: italic;
    color: var(--shu);
  }
  .hero__lede {
    color: var(--mist);
    font-size: var(--step-1);
    max-width: 42ch;
    margin-top: 1.4rem;
  }
  .hero__lede strong {
    color: var(--kinari);
  }
  .hero__lede em {
    font-style: normal;
    color: var(--kin);
  }
  .hero__cta {
    display: flex;
    gap: 0.8rem;
    margin-top: 1.8rem;
    flex-wrap: wrap;
  }
  .hero__install {
    margin-top: 1.6rem;
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--mist);
  }
  .hero__install code {
    background: var(--sumi);
    border: 1px solid var(--line);
    padding: 0.85rem 1.2rem;
    border-radius: 12px;
    display: inline-block;
  }
  .hero__install code::before {
    content: "$ ";
    color: var(--shu);
  }
  @media (max-width: 880px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    /* On mobile the demo follows the copy: eyebrow, title, lede, CTAs, go get,
       then the animation. */
    .hero__demo {
      order: 0;
      margin-top: 0.5rem;
    }
  }

  /* FEATURES */
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.1rem;
  }
  .feature__k {
    font-family: var(--font-mono);
    color: var(--shu);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }
  .feature h3 {
    font-size: var(--step-1);
    margin: 0.6rem 0 0.5rem;
  }
  .feature p {
    color: var(--mist);
    font-size: 0.95rem;
    margin: 0;
  }

  /* QUICKSTART */
  .qs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  .qs__grid pre {
    font-size: 0.95rem;
  }

  /* PROVIDERS (category summary) */
  .cats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }
  .cat {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.3rem 1.4rem;
    text-decoration: none;
  }
  .cat__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .cat__name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: 0;
    color: var(--ink);
  }
  .cat__count {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--green-deep);
    background: var(--green-soft);
    border: 1px solid rgba(47, 158, 104, 0.3);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
  }
  .cat__items {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--muted);
  }
  .providers__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  /* MIDDLEWARE */
  .mw {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .mw__copy p {
    color: var(--mist);
  }
  .mw__list {
    list-style: none;
    padding: 0;
    margin: 1.2rem 0 0;
    display: grid;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: var(--mist);
  }
  .mw__list li {
    padding-left: 1.2rem;
    position: relative;
  }
  .mw__list li::before {
    content: "▸";
    color: var(--shu);
    position: absolute;
    left: 0;
  }
  .mw__list b {
    color: var(--kinari);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .mw__code {
    font-size: 0.92rem;
  }
  @media (max-width: 860px) {
    .mw {
      grid-template-columns: 1fr;
    }
  }

  /* SECURITY */
  .sec {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.1rem;
  }
  .sec h3 {
    font-size: var(--step-1);
    margin-bottom: 0.5rem;
    color: var(--kin);
  }
  .sec p {
    color: var(--mist);
    font-size: 0.92rem;
    margin: 0;
  }

  /* CLOSING */
  .closing {
    text-align: center;
  }
  .closing__inner {
    display: grid;
    justify-items: center;
    gap: 1rem;
  }
  .closing h2 {
    font-size: var(--step-3);
    margin-top: 0.5rem;
  }
  .closing p {
    color: var(--mist);
    max-width: 40ch;
    margin: 0;
  }
  .closing .hero__cta {
    justify-content: center;
  }
</style>
